{
    "$id": "nebula_velodyne/schema/lidar_velodyne.json",
    "$schema": "http://json-schema.org/draft-07/schema#",
    "definitions": {
        "calibration_file": {
            "$ref": "../../../nebula_core/nebula_core_ros/schema/misc.json#/definitions/calibration_file",
            "default": "$(find-pkg-share nebula_velodyne_decoders)/calibration/$(var sensor_model).yaml"
        },
        "return_mode": {
            "$ref": "../../../nebula_core/nebula_core_ros/schema/misc.json#/definitions/return_mode",
            "enum": [
                "SingleStrongest",
                "SingleLast",
                "Dual",
                "SingleFirst"
            ]
        },
        "rotation_speed": {
            "$ref": "../../../nebula_core/nebula_core_ros/schema/hardware.json#/definitions/rotation_speed",
            "default": "600",
            "maximum": 1200,
            "minimum": 300,
            "multipleOf": 60
        },
        "sensor_model": {
            "$ref": "../../../nebula_core/nebula_core_ros/schema/hardware.json#/definitions/sensor_model",
            "enum": [
                "VLP16",
                "VLP32",
                "VLS128"
            ]
        }
    },
    "title": "Lidar Velodyne parameters.",
    "type": "object"
}
