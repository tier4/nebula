{
    "$id": "nebula_hesai/schema/lidar_hesai.json",
    "$schema": "http://json-schema.org/draft-07/schema#",
    "definitions": {
        "blockage_mask_output": {
            "description": "Enables blockage detection and outputs a blockage mask per scan",
            "properties": {
                "horizontal_bin_size_mdeg": {
                    "default": 1000,
                    "description": "The size of the horizontal bins in millidegrees",
                    "maximum": 360000,
                    "minimum": 1,
                    "type": "number"
                }
            },
            "type": "object"
        },
        "calibration_download_enabled": {
            "default": true,
            "description": "Whether to download the calibration data from the sensor and store it in `calibration_file`, or to use the file at `calibration_file` as-is. In `udp_only` and offline (`launch_hw = false`) mode, calibration from file is always used.",
            "type": "boolean"
        },
        "calibration_file": {
            "$ref": "../../../nebula_core/nebula_core_ros/schema/misc.json#/definitions/calibration_file",
            "default": "$(find-pkg-share nebula_hesai_decoders)/calibration/$(var sensor_model).csv"
        },
        "cut_angle": {
            "default": "0.0",
            "description": "The angle in degrees at which pointclouds are cut/published.",
            "maximum": 360,
            "minimum": 0,
            "type": "number"
        },
        "diagnostics": {
            "properties": {
                "functional_safety": {
                    "allOf": [
                        {
                            "if": {
                                "properties": {
                                    "mode": {
                                        "const": "advanced"
                                    }
                                }
                            },
                            "then": {
                                "required": [
                                    "error_definitions_path"
                                ]
                            }
                        }
                    ],
                    "properties": {
                        "error_definitions_path": {
                            "description": "Path to CSV file containing error definitions (required for advanced mode)",
                            "type": "string"
                        },
                        "ignored_error_codes": {
                            "default": [],
                            "description": "List of error codes to ignore in hexadecimal format",
                            "items": {
                                "maximum": 65535,
                                "minimum": 0,
                                "type": "integer"
                            },
                            "type": "array"
                        },
                        "mode": {
                            "default": "basic",
                            "description": "Functional safety diagnostic mode",
                            "enum": [
                                "basic",
                                "advanced"
                            ],
                            "type": "string"
                        }
                    },
                    "required": [
                        "mode"
                    ],
                    "type": "object"
                },
                "packet_loss": {
                    "$ref": "../../../nebula_core/nebula_core_ros/schema/diagnostics.json#/definitions/packet_loss_diagnostic_task"
                },
                "pointcloud_publish_rate": {
                    "$ref": "../../../nebula_core/nebula_core_ros/schema/diagnostics.json#/definitions/rate_bound_status"
                }
            },
            "type": "object"
        },
        "gnss_port": {
            "$ref": "../../../nebula_core/nebula_core_ros/schema/communication.json#/definitions/gnss_port",
            "default": "10110",
            "minimum": 0
        },
        "hires_mode": {
            "default": false,
            "description": "Whether to turn on or off the sensor's high resolution mode",
            "type": "boolean"
        },
        "multicast_ip": {
            "$ref": "../../../nebula_core/nebula_core_ros/schema/communication.json#/definitions/multicast_ip",
            "default": "\"\""
        },
        "ptp_domain": {
            "default": "0",
            "description": "PTP domain (PTP operates within a logical scope).",
            "maximum": 127,
            "minimum": 0,
            "type": "integer"
        },
        "ptp_lock_threshold": {
            "default": "100",
            "description": "The maximum sensor clock offset in microseconds from the master clock which will still be treated as being locked.",
            "maximum": 100,
            "minimum": 1,
            "type": "integer"
        },
        "ptp_profile": {
            "default": "1588v2",
            "description": "PTP profile.",
            "enum": [
                "1588v2",
                "802.1as",
                "automotive"
            ],
            "type": "string"
        },
        "ptp_switch_type": {
            "default": "TSN",
            "description": "For automotive profile,'TSN' or 'NON_TSN'.",
            "enum": [
                "TSN",
                "NON_TSN"
            ],
            "type": "string"
        },
        "ptp_transport_type": {
            "default": "UDP",
            "description": "1588v2 supports 'UDP' or 'L2', other profiles only L2 (HW).",
            "enum": [
                "UDP",
                "L2"
            ],
            "type": "string"
        },
        "rotation_speed": {
            "$ref": "../../../nebula_core/nebula_core_ros/schema/hardware.json#/definitions/rotation_speed",
            "default": "600",
            "maximum": 1200,
            "minimum": 300,
            "multipleOf": 60
        },
        "sensor_model": {
            "$ref": "../../../nebula_core/nebula_core_ros/schema/hardware.json#/definitions/sensor_model",
            "enum": [
                "Pandar64",
                "Pandar40P",
                "PandarXT16",
                "PandarXT32",
                "PandarXT32M",
                "PandarQT64",
                "PandarQT128",
                "Pandar128E4X",
                "PandarAT128"
            ]
        },
        "sync_angle": {
            "default": "0",
            "description": "The angle in whole degrees which should be hit on top-of-second.",
            "maximum": 359,
            "minimum": 0,
            "type": "integer"
        },
        "udp_socket_receive_buffer_size_bytes": {
            "default": "5400000",
            "description": "Kernel UDP receive buffer size (SO_RCVBUF) in bytes for data socket, see `man 7 setsockopt` for details. Increase if packets are dropped due to full UDP queue. Increasing this also increases the worst case latency.",
            "minimum": 256,
            "type": "integer"
        }
    },
    "title": "Lidar Hesai parameters.",
    "type": "object"
}
