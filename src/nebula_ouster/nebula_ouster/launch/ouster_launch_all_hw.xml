<?xml version="1.0"?>
<!--
  Full hardware launch for Nebula Ouster (component container + parameters).

  Ensure connection.* matches udp_port_lidar and sensor_http_base_url matches the replay HTTP API
  so PacketFormat (e.g. DUAL vs LEGACY) matches the UDP stream.
-->
<launch>
    <arg name="launch_hw" default="true" description="Bind UDP and receive live packets"/>
    <arg name="config_file"
         default="$(find-pkg-share nebula_ouster)/config/ouster_sensor.param.yaml"/>
    <arg name="sensor_model" default="ouster_sensor" description="Reported sensor model string"/>

    <node_container pkg="rclcpp_components" exec="component_container" name="nebula_ouster_container"
                    namespace="">
        <composable_node pkg="nebula_ouster" plugin="nebula::ros::OusterRosWrapper"
                         name="nebula_ouster_ros_wrapper">
            <param from="$(var config_file)" allow_substs="true"/>
            <param name="launch_hw" value="$(var launch_hw)"/>
            <param name="sensor_model" value="$(var sensor_model)"/>
        </composable_node>
    </node_container>
</launch>
