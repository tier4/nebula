{
    "$id": "nebula_ros_base/schema/communication.json",
    "$schema": "http://json-schema.org/draft-07/schema#",
    "definitions": {
        "configuration_host_port": {
            "default": "42401",
            "description": "Host configuration port.",
            "minimum": 0,
            "readOnly": true,
            "type": "integer"
        },
        "configuration_sensor_port": {
            "default": "42101",
            "description": "Sensor configuration port.",
            "minimum": 0,
            "readOnly": true,
            "type": "integer"
        },
        "data_port": {
            "default": "2368",
            "description": "Sensor data port.",
            "minimum": 0,
            "readOnly": true,
            "type": "integer"
        },
        "filters": {
            "default": "0:0",
            "description": "candump-style filters for CAN frames.",
            "type": "string"
        },
        "gnss_port": {
            "default": "2369",
            "description": "GNSS port.",
            "minimum": 0,
            "readOnly": true,
            "type": "integer"
        },
        "host_ip": {
            "default": "255.255.255.255",
            "description": "Host IPv4 address.",
            "pattern": "^((25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\\.){3}(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)$",
            "readOnly": true,
            "type": "string"
        },
        "interface": {
            "default": "can",
            "description": "CAN interface name.",
            "type": "string"
        },
        "multicast_ip": {
            "default": "224.0.0.2",
            "description": "Multicast IPv4 address.",
            "pattern": "(^((22[4-9]|23[0-9])\\.)((25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\\.){2}(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)$)|",
            "readOnly": true,
            "type": "string"
        },
        "packet_mtu_size": {
            "default": "1500",
            "description": "Packet MTU size.",
            "minimum": 0,
            "readOnly": true,
            "type": "integer"
        },
        "receiver_timeout_sec": {
            "default": "0.03",
            "description": "Timeout for reading data from the CAN bus.",
            "minimum": 0.0,
            "type": "number"
        },
        "sender_timeout_sec": {
            "default": "0.01",
            "description": "Timeout for sending data to the CAN bus.",
            "minimum": 0.0,
            "type": "number"
        },
        "sensor_ip": {
            "default": "192.168.1.201",
            "description": "Sensor IPv4 address.",
            "pattern": "^((25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\\.){3}(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)$",
            "readOnly": true,
            "type": "string"
        }
    },
    "title": "Communication parameters.",
    "type": "object"
}
