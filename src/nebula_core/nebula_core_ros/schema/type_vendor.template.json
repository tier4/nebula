        "example_parameter_3": {
            "$comment": "Wrong! If no changes declare parameter in schema/<sensor_model>.schema.json.",
            "$ref": "hardware.json#/definitions/example_parameter_3"
        },
        "sensor_model": {
            "$ref": "hardware.json#/definitions/sensor_model",
