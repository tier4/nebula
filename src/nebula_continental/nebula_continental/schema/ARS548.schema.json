{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "additionalProperties": false,
    "definitions": {
        "ARS548": {
            "properties": {
                "base_frame": {
                    "$ref": "../../../nebula_core/nebula_core_ros/schema/topic.json#/definitions/base_frame"
                },
                "configuration_host_port": {
                    "$ref": "../../../nebula_core/nebula_core_ros/schema/communication.json#/definitions/configuration_host_port"
                },
                "configuration_sensor_port": {
                    "$ref": "../../../nebula_core/nebula_core_ros/schema/communication.json#/definitions/configuration_sensor_port"
                },
                "configuration_vehicle_height": {
                    "$ref": "../../../nebula_core/nebula_core_ros/schema/misc.json#/definitions/configuration_vehicle_height"
                },
                "configuration_vehicle_length": {
                    "$ref": "../../../nebula_core/nebula_core_ros/schema/misc.json#/definitions/configuration_vehicle_length"
                },
                "configuration_vehicle_wheelbase": {
                    "$ref": "../../../nebula_core/nebula_core_ros/schema/misc.json#/definitions/configuration_vehicle_wheelbase"
                },
                "configuration_vehicle_width": {
                    "$ref": "../../../nebula_core/nebula_core_ros/schema/misc.json#/definitions/configuration_vehicle_width"
                },
                "data_port": {
                    "$ref": "../../../nebula_core/nebula_core_ros/schema/communication.json#/definitions/data_port"
                },
                "diagnostics": {
                    "properties": {
                        "blockage": {
                            "properties": {
                                "num_frame_transition": {
                                    "default": 5,
                                    "description": "Number of frames to wait before transitioning diagnostic status for blockage.",
                                    "minimum": 1,
                                    "type": "integer"
                                },
                                "status_level": {
                                    "properties": {
                                        "ok": {
                                            "default": "2",
                                            "description": "Maximum blockage status level considered as OK (0: Blind, 1: High, 2: Mid, 3: Low, 4: None)",
                                            "maximum": 4,
                                            "minimum": 0,
                                            "type": "integer"
                                        },
                                        "warn": {
                                            "default": "1",
                                            "description": "Maximum blockage status level considered as Warning (0: Blind, 1: High, 2: Mid, 3: Low, 4: None). Can not be greater than `ok`. If `ok` is equal to `warn`, the status will be set to `ERROR` if the blockage status is greater than `ok`.",
                                            "maximum": 4,
                                            "minimum": 0,
                                            "type": "integer"
                                        }
                                    },
                                    "required": [
                                        "ok",
                                        "warn"
                                    ],
                                    "type": "object"
                                },
                                "test_level": {
                                    "properties": {
                                        "ok": {
                                            "default": "1",
                                            "description": "Maximum blockage test level considered as OK (0: Self test failed, 1: Self test passed, 2: Self test ongoing)",
                                            "maximum": 2,
                                            "minimum": 0,
                                            "type": "integer"
                                        },
                                        "warn": {
                                            "default": "1",
                                            "description": "Maximum blockage test level considered as Warning (0: Self test failed, 1: Self test passed, 2: Self test ongoing). Can not be greater than `ok`. If `ok` is equal to `warn`, the status will be set to `ERROR` if the blockage test is greater than `ok`.",
                                            "maximum": 2,
                                            "minimum": 0,
                                            "type": "integer"
                                        }
                                    },
                                    "required": [
                                        "ok",
                                        "warn"
                                    ],
                                    "type": "object"
                                }
                            },
                            "type": "object"
                        },
                        "internal": {
                            "properties": {
                                "num_frame_transition": {
                                    "default": 10,
                                    "description": "Number of frames to wait before transitioning diagnostic status for internal errors.",
                                    "minimum": 1,
                                    "type": "integer"
                                }
                            },
                            "type": "object"
                        },
                        "rate_bound_status": {
                            "$ref": "../../../nebula_core/nebula_core_ros/schema/diagnostics.json#/definitions/rate_bound_status"
                        }
                    },
                    "type": "object"
                },
                "frame_id": {
                    "$ref": "../../../nebula_core/nebula_core_ros/schema/topic.json#/definitions/frame_id"
                },
                "host_ip": {
                    "$ref": "../../../nebula_core/nebula_core_ros/schema/communication.json#/definitions/host_ip"
                },
                "launch_hw": {
                    "$ref": "../../../nebula_core/nebula_core_ros/schema/hardware.json#/definitions/launch_hw"
                },
                "multicast_ip": {
                    "$ref": "../../../nebula_core/nebula_core_ros/schema/communication.json#/definitions/multicast_ip"
                },
                "object_frame": {
                    "$ref": "../../../nebula_core/nebula_core_ros/schema/topic.json#/definitions/object_frame"
                },
                "radar_info_rate_subsample": {
                    "$ref": "../../../nebula_core/nebula_core_ros/schema/topic.json#/definitions/radar_info_rate_subsample"
                },
                "sensor_ip": {
                    "$ref": "../../../nebula_core/nebula_core_ros/schema/communication.json#/definitions/sensor_ip"
                },
                "sensor_model": {
                    "$ref": "radar_continental.json#/definitions/sensor_model",
                    "enum": [
                        "ARS548"
                    ]
                },
                "sync_diagnostics": {
                    "$ref": "../../../nebula_core/nebula_core_ros/schema/misc.json#/definitions/sync_diagnostics"
                },
                "use_sensor_time": {
                    "$ref": "../../../nebula_core/nebula_core_ros/schema/topic.json#/definitions/use_sensor_time"
                }
            },
            "required": [
                "host_ip",
                "sensor_ip",
                "multicast_ip",
                "data_port",
                "configuration_host_port",
                "configuration_sensor_port",
                "launch_hw",
                "configuration_vehicle_length",
                "configuration_vehicle_width",
                "configuration_vehicle_height",
                "configuration_vehicle_wheelbase",
                "sensor_model",
                "diagnostics"
            ],
            "type": "object"
        }
    },
    "properties": {
        "/**": {
            "additionalProperties": false,
            "properties": {
                "ros__parameters": {
                    "$ref": "#/definitions/ARS548"
                }
            },
            "required": [
                "ros__parameters"
            ],
            "type": "object"
        }
    },
    "required": [
        "/**"
    ],
    "title": "Radar Continental ARS548 parameters.",
    "type": "object"
}
